# ==================== MongoDB Configuration ====================
# Your MongoDB connection string
# Example: mongodb://localhost:27017/whatsask
# Example (MongoDB Atlas): mongodb+srv://username:password@cluster.mongodb.net/whatsask
MONGODB_URI=

# ==================== Telegram Bot Configuration ====================
# Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Your Telegram bot username (without @)
# Example: WhatsTaskBot
TELEGRAM_BOT_USERNAME=

# ==================== Next.js Configuration ====================
# Set to 'development' or 'production'
NODE_ENV=development

# Your app URL (for production deployment)
# Example: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=

# ==================== Admin Configuration ====================
# Your Telegram ID (the admin who receives notifications)
# Get this by messaging @userinfobot on Telegram
# Example: 123456789
ADMIN_TELEGRAM_ID=

# ==================== AI Configuration (Optional) ====================
# For AI-powered features like task parsing and project generation
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=

# ==================== Optional: Additional Configuration ====================
# If you need to override the default port
# PORT=3000

# If you want to enable debug logging
# DEBUG=true
