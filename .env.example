# ==================== Database Configuration ====================
# Neon PostgreSQL connection string
# Get from: https://console.neon.tech → your project → Connection Details
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ==================== Telegram Bot Configuration ====================
# Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
BOT_TOKEN=

# Your Telegram bot username (without @)
TELEGRAM_BOT_USERNAME=

# ==================== Next.js Configuration ====================
NODE_ENV=development

# Your app URL (for production deployment)
NEXT_PUBLIC_APP_URL=

# ==================== Admin Configuration ====================
# Your Telegram ID (the admin who receives notifications)
ADMIN_TELEGRAM_ID=

# ==================== AI Configuration (Optional) ====================
# For AI-powered features like task parsing and project generation
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=
